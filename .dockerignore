# VCS / local env
.git
.gitignore
.venv
.python-version
.vscode
.idea

# Python cache/artifacts
__pycache__/
*.py[cod]
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

