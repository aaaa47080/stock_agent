{
  "tier_modes": {
    "free": {
      "allowed_modes": [
        "quick"
      ],
      "default_mode": "quick"
    },
    "premium": {
      "allowed_modes": [
        "quick",
        "verified"
      ],
      "default_mode": "verified"
    }
  },
  "query_types": {
    "price_lookup": {
      "patterns": [
        "價格",
        "股價",
        "現在多少",
        "多少錢",
        "幾塊",
        "price",
        "quote",
        "trading at"
      ],
      "requires_symbol_candidates": true
    }
  },
  "modes": {
    "verified": {
      "price_lookup": {
        "resolved_role": "market_lookup",
        "resolved_fail_reason": "verified_tool_unavailable",
        "discovery_role": "discovery_lookup",
        "discovery_fail_reason": "verified_discovery_tool_unavailable"
      }
    }
  }
}
