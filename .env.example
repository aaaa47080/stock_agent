# =============================================================
# Pi Crypto Insight — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================

# === Application ===
ENVIRONMENT=development
APP_LOG_LEVEL=WARNING
WEB_CONCURRENCY=1

# === Database (Required) ===
DATABASE_URL=postgresql://user:pass@localhost:5432/cryptomind

# === Security (Required — generate with: openssl rand -hex 32) ===
JWT_SECRET_KEY=
ADMIN_API_KEY=

# === LLM Providers (at least one required for AI features) ===
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# === Redis (Optional — defaults to memory:// if not set) ===
REDIS_URL=redis://localhost:6379/0

# === Pi Network ===
PI_API_KEY=
PI_WALLET_PRIVATE_SEED=
PI_VALIDATION_KEY=

# === OKX Exchange ===
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# === Test Mode (MUST be false in production) ===
TEST_MODE=false

# === SSL Verification ===
SSL_VERIFY=true

# === ORM Auto-Migrate ===
ORM_AUTO_MIGRATE=true

# === Skip DB init on startup ===
SKIP_DB_INIT=false
